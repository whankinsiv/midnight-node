{
  "packageManager": "npm@9.8.0",
  "name": "@midnight-ntwrk/node-toolkit",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "description": "Interface gateway between Rust `midnight-node-toolkit` and TS `@midnight-ntwrk` packages",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "bin": {
    "midnight-node-toolkit-js": "dist/bin.js"
  },
  "workspaces": [
    ".",
    "compact-*"
  ],
  "scripts": {
    "build": "npm run build:variants && tsc && chmod +x dist/bin.js",
    "build:variants": "turbo run build --filter='@midnight-ntwrk/node-toolkit-compact-*'",
    "start": "dist/bin.js",
    "test": "npm run build:variants && npm run build-compact && vitest run",
    "test:compat": "./scripts/test-all-compactc.sh",
    "build-compact": "(shx --negate test -d ./test/contract/managed && npm run compact || true)",
    "compact": "fetch-compactc && npm run compact-counter && npm run compact-mint && npm run compact-tokens-minter",
    "compact-counter": "run-compactc ./test/contract/counter.compact ./test/contract/managed/counter",
    "compact-tokens-minter": "run-compactc ./test/minter_contract/minter.compact ./test/minter_contract/out",
    "compact-mint": "run-compactc ./mint/mint.compact ./mint/out"
  },
  "dependencies": {
    "@midnight-ntwrk/node-toolkit-compact-0.29.0": "^0.1.0",
    "@midnight-ntwrk/node-toolkit-compact-0.30.0": "^0.1.0",
    "@midnight-ntwrk/node-toolkit-compact-0.31.0": "^0.1.0",
    "@midnight-ntwrk/node-toolkit-compact-0.33.0": "^0.1.0",
    "effect": "^3.21.0"
  },
  "devDependencies": {
    "@midnight-ntwrk/midnight-js-compact": "4.0.4",
    "@tsconfig/node24": "24.0.0",
    "@types/node": "22.18.10",
    "shx": "0.4.0",
    "typescript": "5.9.3",
    "vitest": "4.1.0",
    "turbo": "2.9.14"
  },
  "overrides": {
    "esbuild": "0.28.1",
    "@midnightntwrk/ledger-v9": "1.0.0-rc.3",
    "@midnightntwrk/onchain-runtime-v4": "4.0.0-rc.3"
  }
}
